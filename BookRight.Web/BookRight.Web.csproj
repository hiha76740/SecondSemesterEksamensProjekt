<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
    <UserSecretsId>3341acec-2e34-4592-94ee-206f56c8f17e</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.7">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BookRight.ApplicationLib\BookRight.ApplicationLib.csproj" />
    <ProjectReference Include="..\BookRight.FacadeLib\BookRight.FacadeLib.csproj" />
    <ProjectReference Include="..\BookRight.InfrastructureLib\BookRight.InfrastructureLib.csproj" />
  </ItemGroup>

</Project>
